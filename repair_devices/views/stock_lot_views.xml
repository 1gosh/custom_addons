<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- HiFi Unit: Tree view -->
    <record id="view_hifi_unit_tree" model="ir.ui.view">
        <field name="name">stock.lot.hifi.tree</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" string="N° Série"/>
                <field name="product_id" string="Appareil"/>
                <field name="hifi_partner_id" string="Propriétaire"/>
                <field name="hifi_variant_id" string="Variante" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- HiFi Unit: Form view (inherit stock.lot form) -->
    <record id="view_hifi_unit_form" model="ir.ui.view">
        <field name="name">stock.lot.hifi.form.inherit</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">

            <!-- Declare is_hifi_unit for visibility throughout the form -->
            <xpath expr="//field[@name='display_complete']" position="after">
                <field name="is_hifi_unit" invisible="1"/>
            </xpath>

            <!-- Hide standard main_group for HiFi units -->
            <xpath expr="//group[@name='main_group']" position="attributes">
                <attribute name="invisible">is_hifi_unit</attribute>
            </xpath>

            <!-- HiFi layout: device info + status columns -->
            <xpath expr="//group[@name='main_group']" position="before">
                <group name="hifi_device_group" invisible="not is_hifi_unit">
                    <group string="Appareil">
                        <field name="product_id" string="Modèle"
                            context="{'default_is_hifi_device': True, 'default_detailed_type': 'product', 'default_tracking': 'serial'}"
                            readonly="context.get('set_product_readonly', False)" force_save="1"/>
                        <field name="hifi_variant_id"/>
                        <field name="hifi_partner_id"/>
                    </group>
                    <group name="hifi_status_group" string="Statut">
                    </group>
                </group>
            </xpath>

            <!-- Ensure notebook is visible for HiFi units (base hides it when not display_complete) -->
            <xpath expr="//notebook" position="attributes">
                <attribute name="invisible">not display_complete and not is_hifi_unit</attribute>
            </xpath>

            <!-- Notes tab for HiFi (before base Description) -->
            <xpath expr="//page[@name='description']" position="before">
                <page string="Notes" name="hifi_notes_page" invisible="not is_hifi_unit">
                    <field name="hifi_notes" placeholder="Notes techniques, observations..." nolabel="1"/>
                </page>
            </xpath>

            <!-- Hide base Description page for HiFi (replaced by Notes above) -->
            <xpath expr="//page[@name='description']" position="attributes">
                <attribute name="invisible">is_hifi_unit</attribute>
            </xpath>

        </field>
    </record>

    <!-- HiFi Unit: Search view -->
    <record id="view_hifi_unit_search" model="ir.ui.view">
        <field name="name">stock.lot.hifi.search</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <search string="Appareils physiques">
                <field name="name" string="N° Série"/>
                <field name="product_id" string="Appareil"/>
                <field name="hifi_partner_id" string="Propriétaire"/>
                <field name="hifi_variant_id"/>
                <group name="group_by" expand="0" string="Grouper par">
                    <filter name="group_device" string="Appareil" context="{'group_by': 'product_id'}"/>
                    <filter name="group_partner" string="Propriétaire" context="{'group_by': 'hifi_partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: HiFi Physical Units -->
    <record id="action_hifi_unit" model="ir.actions.act_window">
        <field name="name">Appareils physiques</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_hifi_unit', '=', True)]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_hifi_unit_search"/>
    </record>

    </data>
</odoo>
