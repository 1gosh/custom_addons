<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- HiFi Device Catalog: Tree view -->
    <record id="view_hifi_device_tree" model="ir.ui.view">
        <field name="name">product.template.hifi.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="brand_id"/>
                <field name="name"/>
                <field name="hifi_variant_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}" string="Variantes"/>
                <field name="categ_id" string="Catégorie"/>
                <field name="hifi_unit_count" string="Nb d'enregistrements"/>
            </tree>
        </field>
    </record>

    <!-- HiFi Device Catalog: Search view -->
    <record id="view_hifi_device_search" model="ir.ui.view">
        <field name="name">product.template.hifi.search</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Catalogue d'appareils">
                <field name="name" string="Recherche" filter_domain="[
                    '|', '|', ('brand_id.name', 'ilike', self), ('name', 'ilike', self), ('display_name', 'ilike', self)
                ]"/>
                <field name="brand_id"/>
                <field name="categ_id"/>
                <field name="production_year"/>
                <field name="hifi_variant_ids"/>
                <group expand="0" string="Filtres">
                    <filter name="filter_brand" string="Marque" context="{'group_by': 'brand_id'}"/>
                    <filter name="filter_category" string="Catégorie" context="{'group_by': 'categ_id'}"/>
                    <filter name="filter_year" string="Année de sortie" context="{'group_by': 'production_year'}"/>
                </group>
                <searchpanel>
                    <field name="categ_id"
                            enable_counters="1"
                            icon="fa-folder"
                            string="Catégories"/>
                    <field name="brand_id"
                            enable_counters="1"
                            icon="fa-tag"
                            select="multi"
                            string="Marques"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- HiFi Device Catalog: Form view (inherit product.template form) -->
    <record id="view_hifi_device_form" model="ir.ui.view">
        <field name="name">product.template.hifi.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Declare is_hifi_device early for visibility conditions -->
            <xpath expr="//field[@name='product_variant_count']" position="after">
                <field name="is_hifi_device" invisible="1"/>
            </xpath>

            <!-- Name placeholder for HiFi -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">ex: BEOGRAM 3000</attribute>
                <attribute name="string">Modèle</attribute>
            </xpath>

            <!-- HiFi units stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_lots" type="object" class="oe_stat_button"
                    icon="fa-cube" invisible="not is_hifi_device">
                    <field name="hifi_unit_count" widget="statinfo" string="Appareils physiques"/>
                </button>
            </xpath>

            <!-- Hide priority for HiFi -->
            <xpath expr="//field[@name='priority']" position="attributes">
                <attribute name="invisible">is_hifi_device</attribute>
            </xpath>

            <!-- Replace options: restore checkboxes for non-HiFi, HiFi info for HiFi -->
            <xpath expr="//div[@name='options']" position="replace">
                <div name="options" invisible="is_hifi_device">
                    <span class="d-inline-flex">
                        <field name="sale_ok"/>
                        <label for="sale_ok"/>
                    </span>
                    <span class="d-inline-flex">
                        <field name="purchase_ok"/>
                        <label for="purchase_ok"/>
                    </span>
                </div>
                <group name="hifi_info_group" invisible="not is_hifi_device">
                    <group>
                        <field name="brand_id" required="is_hifi_device"/>
                        <field name="categ_id" required="is_hifi_device"
                            domain="[('id', 'child_of', %(repair_devices.product_category_hifi)d)]"
                            string="Catégorie HiFi"/>
                    </group>
                    <group>
                        <field name="hifi_variant_ids" widget="many2many_tags"
                            options="{'color_field': 'color', 'no_create_edit': True}"
                            placeholder="Ajouter des variantes" string="Variantes"/>
                        <field name="production_year"/>
                    </group>
                </group>
            </xpath>

            <!-- Hide General Information page for HiFi -->
            <xpath expr="//page[@name='general_information']" position="attributes">
                <attribute name="invisible">is_hifi_device</attribute>
            </xpath>

            <!-- Hide Attributes & Variants page for HiFi -->
            <xpath expr="//page[@name='variants']" position="attributes">
                <attribute name="invisible">is_hifi_device</attribute>
            </xpath>

            <!-- HiFi tabs: Notes + Détails techniques (before hidden General Information) -->
            <xpath expr="//page[@name='general_information']" position="before">
                <page string="Notes" name="hifi_notes_page" invisible="not is_hifi_device">
                    <field name="description" nolabel="1"
                        placeholder="Notes internes sur cet appareil..."/>
                </page>
                <page string="Détails techniques" name="hifi_technical_page" invisible="not is_hifi_device">
                    <group>
                        <group>
                            <field name="detailed_type" string="Type de produit"/>
                            <field name="uom_id" groups="uom.group_uom"/>
                            <field name="uom_po_id" groups="uom.group_uom"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <label for="list_price"/>
                            <div class="o_row">
                                <field name="list_price" class="oe_inline" widget="monetary"
                                    options="{'currency_field': 'currency_id', 'field_digits': True}"/>
                            </div>
                            <field name="standard_price" widget="monetary"
                                options="{'currency_field': 'cost_currency_id', 'field_digits': True}"/>
                            <field name="default_code" string="Référence interne"/>
                            <field name="barcode"/>
                        </group>
                    </group>
                    <field name="product_properties" columns="2"/>
                </page>
            </xpath>

        </field>
    </record>

    <!-- HiFi Device Catalog: Kanban view -->
    <record id="view_hifi_device_kanban" model="ir.ui.view">
        <field name="name">product.template.hifi.kanban</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" quick_create="false">
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="row mb-0">
                                <div class="col-6">
                                    <strong><field name="brand_id"/></strong> <field name="name"/>
                                </div>
                                <div class="col-6 text-end">
                                    <field name="categ_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action: HiFi Device Catalog -->
    <record id="action_hifi_device_catalog" model="ir.actions.act_window">
        <field name="name">Catalogue d'appareils</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('is_hifi_device', '=', True)]</field>
        <field name="context" eval="{'default_categ_id': ref('product_category_hifi')}"/>
        <field name="search_view_id" ref="view_hifi_device_search"/>
    </record>

    </data>
</odoo>
