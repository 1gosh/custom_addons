<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_check_overdue_rentals" model="ir.cron">
            <field name="name">Location : Vérifier les retards</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_overdue_rentals()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_repair_quote_process" model="ir.cron">
            <field name="name">Réparation : traiter les devis en attente</field>
            <field name="model_id" ref="model_repair_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_pending_quotes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
