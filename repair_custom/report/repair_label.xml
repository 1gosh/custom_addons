<odoo>
    <template id="repair_custom.report_repair_label">
        <t t-set="full_width" t-value="True"/>
        <t t-call="web.html_container">
            <meta charset="utf-8"/>
            <style>
                body, body.container-fluid, #wrapwrap, main {
                    padding: 0 !important;
                    margin: 0 !important;
                }
                .label-page {
                    width: 68mm;
                    padding: 0;
                    font-family: 'Arial', sans-serif;
                    color: #000;
                    position: relative;
                }
                .label-page table {
                    width: 100%;
                    table-layout: fixed;
                    border-collapse: collapse;
                }
                .body {
                    -webkit-text-stroke: 2px white;
                }
                .warranty-watermark {
                    position: absolute;
                    right: 0;
                    bottom: 0;
                    z-index: -1;
                    font-weight: bold;
                    font-size: 25mm;
                    line-height: 1;
                    color: rgb(228, 228, 228);
                    transform: scaleY(1.5);
                }
                .sar-info {
                    font-size: 8px;
                    margin-bottom: 1mm;
                }
                .customer-name {
                    font-size: 19px;
                    font-weight: 900;
                    line-height: 0.8;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }
                .customer-phone {
                    font-size: 9px;
                }
                .entry-date {
                    font-size: 27px;
                    font-weight: 900;
                    letter-spacing: -1px;
                    line-height: 0.8;
                }
                .device-name {
                    line-height: 0.9;
                    font-size: 14px;
                    font-weight: bold;
                    word-wrap: break-word;
                }
                .device-details {
                    font-size: 8px;
                    overflow: hidden;
                    white-space: nowrap;
                }
                .device-notes {
                    font-size: 8px;
                    margin-top: 1mm;
                }
                .quote-box {
                    margin-bottom: 1mm;
                    font-weight: bold;
                    font-size: 10px;
                    border: 1px solid black;
                    padding: 1px;
                    text-align: center;
                }
                .tag-list {
                    font-size: 12px;
                    margin-top: -1px;
                    margin-left: 2mm;
                    word-wrap: break-word;
                    line-height: 1;
                }
                .tag-list-empty {
                    font-style: italic;
                    font-weight: normal;
                    font-size: 10px;
                }
                .label-meta {
                    font-size: 8px;
                    margin-top: 1mm;
                    overflow: hidden;
                    white-space: nowrap;
                }
                .checkbox-row {
                    margin-top: 1.5mm;
                    font-size: 8px;
                    line-height: 2;
                }
                .checkbox-row td {
                    padding: 0.5mm 0;
                }
                .checkbox {
                    display: inline-block;
                    width: 3mm;
                    height: 3mm;
                    border: 1px solid #000;
                    vertical-align: -1.2mm;
                    margin-right: 1mm;
                }
            </style>

            <t t-foreach="docs" t-as="o">
                <div class="label-page">
                    <!-- Warranty watermark (behind content) -->
                    <t t-if="o.repair_warranty != 'aucune'">
                        <span class="warranty-watermark" t-field="o.repair_warranty"/>
                    </t>

                    <!-- SAR previous technician info -->
                    <div class="sar-info" t-if="o.repair_warranty == 'sar'">
                        ℹ Vu par <span style="font-weight:bold;" t-field="o.previous_technician_id.name"/> le <span t-field="o.previous_end_date" t-options='{"widget": "date"}'/>
                    </div>

                    <!-- Row 1: Customer name + entry date -->
                    <table style="margin-bottom: 1mm;">
                        <tr>
                            <td style="width: 72%; vertical-align: top; overflow: hidden;">
                                <div class="customer-name">
                                    <span t-field="o.partner_id.name"/>
                                </div>
                                <div class="customer-phone">
                                    <span t-field="o.partner_id.phone"/>
                                </div>
                            </td>
                            <td style="width: 28%; text-align: right; vertical-align: top; white-space: nowrap;">
                                <div class="entry-date" t-field="o.entry_date" t-options='{"widget": "date", "format": "dd/MM"}'/>
                            </td>
                        </tr>
                    </table>

                    <!-- Row 2: Device info + tags -->
                    <table class="body">
                        <tr>
                            <td style="width: 45%; vertical-align: top;">
                                <div class="device-name">
                                    <span t-field="o.device_id_name"/>
                                </div>
                                <table style="margin-top: 1mm;">
                                    <tr>
                                        <td style="vertical-align: middle; padding: 0;">
                                            <t t-if="o.category_short_name">
                                                <span class="device-details" t-field="o.category_short_name"/>
                                            </t>
                                            <div class="device-details">
                                                <span>S/N: </span><span t-field="o.serial_number"/>
                                            </div>
                                            <div class="device-details">
                                                <span>Réf: </span><span t-field="o.name"/>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                                <div class="device-notes">
                                    <t t-if="o.notes">
                                        <i><span t-field="o.notes"/></i>
                                    </t>
                                </div>
                            </td>

                            <td style="width: 55%; vertical-align: top;">
                                <div t-if="o.quote_required" class="quote-box">
                                    <t t-if="o.quote_threshold > 0">
                                        Devis &gt; <span t-field="o.quote_threshold"
                                                        t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                    </t>
                                    <t t-else="">
                                        Devis Exigé
                                    </t>
                                </div>
                                <div class="tag-list">
                                    <t t-foreach="o.tag_ids" t-as="tag">
                                        - <span t-field="tag.name"/><br/>
                                    </t>
                                    <span t-if="not o.tag_ids" class="tag-list-empty">RAS</span>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- Category + Location -->
                    <div class="label-meta">
                        <t t-if="o.pickup_location_id">
                            ⚲ <span t-field="o.pickup_location_id.name"/>
                        </t>
                    </div>

                    <!-- Tracking checkboxes -->
                    <table class="checkbox-row">
                        <tr>
                            <td>
                                <span class="checkbox"/> Att. pièces
                            </td>
                            <td>
                                <span class="checkbox"/> Pièces reçues
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%;">
                                <span class="checkbox"/> Diag/Devis
                            </td>
                            <td style="width: 50%;">
                                <span class="checkbox"/> Réparé
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
