<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sale_order_form_inherit_repair" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.repair</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <!-- Stat buttons -->
                <xpath expr="//button[@name='action_view_invoice']" position="after">
                    <button
                        name="action_show_repair"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="repair_count == 0"
                        groups="stock.group_stock_user">
                        <field name="repair_count" widget="statinfo" string="Repairs"/>
                    </button>
                </xpath>

                <!-- Wizard button in header -->
                <xpath expr="//header" position="inside">
                    <field name="computed_order_type" invisible="1"/>
                    <field name="stock_location_id" invisible="1"/>
                    <field name="rental_end_date" invisible="1"/>
                    <button name="action_return_rental"
                        string="Marquer Retourné"
                        type="object"
                        class="btn-success"
                        icon="fa-undo"
                        invisible="computed_order_type != 'rental' or rental_state not in ('active', 'overdue')"/>
                </xpath>

                <!-- Rental fields group before order lines -->
                <xpath expr="//field[@name='sale_order_template_id']" position="after">
                    <field name="rental_start_date"
                    string="Dates de location"
                    widget="daterange"
                    options="{'end_date_field': 'rental_end_date', 'show_time':false}"
                    required="computed_order_type == 'rental'"
                    readonly="state != 'draft'"
                    invisible="computed_order_type != 'rental'"
                    />
                    <field name="rental_return_date" invisible="computed_order_type != 'rental' or rental_state not in ('returned',)"/>
                </xpath>

                <xpath expr="//field[@name='payment_term_id']" position="before">
                    <field name="rental_state" widget="badge" invisible="computed_order_type != 'rental'"
                        decoration-info="rental_state == 'draft'"
                        decoration-success="rental_state in ('active', 'returned')"
                        decoration-danger="rental_state == 'overdue'"/>
                    <field name="rental_notes" placeholder="Notes sur la location..." invisible="computed_order_type != 'rental'"/>
                </xpath>

                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <!-- Category + Lot on order lines -->
                <xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id']" position="before">
                    <field name="categ_id" optional="show" string="Catégorie"
                        column_invisible="parent.computed_order_type in ('standard', 'repair_quote')"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id']" position="attributes">
                    <attribute name="domain">[('sale_ok', '=', True)] + ([('categ_id', 'child_of', categ_id)] if categ_id else [])</attribute>
                    <attribute name="context">{'default_categ_id': categ_id}</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/tree/field[@name='product_template_id']" position="after">
                    <field name="lot_id" optional="show" string="N° Série (Stock)"
                        column_invisible="parent.computed_order_type in ('standard', 'repair_quote')"
                        domain="[('product_id.product_tmpl_id', '=', product_template_id), ('location_id', '=', parent.stock_location_id)]"
                        context="{'default_product_id': product_id, 'lot_display': 'serial_only'}"/>
                    <button name="action_generate_serial" type="object"
                        icon="fa-barcode" title="Générer N° Série"
                        column_invisible="parent.computed_order_type in ('standard', 'repair_quote')"
                        invisible="lot_id"/>
                </xpath>

                <!-- Hide "Delivered" column for rental orders -->
                <xpath expr="//field[@name='order_line']/tree/field[@name='qty_delivered']" position="attributes">
                    <attribute name="column_invisible">parent.computed_order_type == 'rental'</attribute>
                </xpath>
           </field>
        </record>
        <record id="view_order_form_repair_quote_theme_a" model="ir.ui.view">
            <field name="name">sale.order.form.repair.quote.theme.a</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@id='create_invoice']" position="attributes">
                    <attribute name="invisible">computed_order_type == 'repair_quote'</attribute>
                </xpath>
                <xpath expr="//button[@id='create_invoice']" position="after">
                    <button name="action_invoice_repair_quote"
                            type="object"
                            string="Facturer le devis"
                            class="btn-primary"
                            invisible="computed_order_type != 'repair_quote' or invoice_status not in ['to invoice', 'upselling']"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
