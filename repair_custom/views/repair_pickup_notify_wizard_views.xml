<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_pickup_notify_wizard_form" model="ir.ui.view">
        <field name="name">repair.pickup.notify.wizard.form</field>
        <field name="model">repair.pickup.notify.wizard</field>
        <field name="arch" type="xml">
            <form string="Notifier le client">
                <div invisible="repair_count > 1">
                    <p>
                        Le dossier <field name="batch_id" readonly="1"/> (<field name="repair_count"/> appareil) est maintenant complet.
                    </p>
                    <p>
                        Souhaitez-vous notifier <field name="partner_name" readonly="1"/> que son appareil est prêt pour le retrait ?
                    </p>
                    
                </div>
                <div invisible="repair_count == 1">
                    <p>
                        Le dossier <field name="batch_id" readonly="1"/> (<field name="repair_count"/> appareils) est maintenant complet.
                    </p>
                    <p>
                        Souhaitez-vous notifier <field name="partner_name" readonly="1"/> que ses appareils sont prêts pour le retrait ?
                    </p>
                </div>
                <footer>
                    <button name="action_send" type="object"
                            string="Envoyer la notification"
                            class="btn-primary"/>
                    <button name="action_postpone" type="object"
                            string="Plus tard"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
