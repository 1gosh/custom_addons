<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_pickup_closure_tree" model="ir.ui.view">
        <field name="name">repair.pickup.closure.tree</field>
        <field name="model">repair.pickup.closure</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="location_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </tree>
        </field>
    </record>
    <record id="view_repair_pickup_closure_form" model="ir.ui.view">
        <field name="name">repair.pickup.closure.form</field>
        <field name="model">repair.pickup.closure</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="location_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_repair_pickup_closure" model="ir.actions.act_window">
        <field name="name">Fermetures retrait</field>
        <field name="res_model">repair.pickup.closure</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
