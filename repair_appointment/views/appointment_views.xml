<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view -->
    <record id="view_repair_pickup_appointment_tree" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.tree</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'no_show'"
                  decoration-muted="state in ('cancelled','done')"
                  decoration-bf="state == 'pending'">
                <field name="pickup_date"/>
                <field name="partner_id"/>
                <field name="device_count" string="Nb."/>
                <field name="device_summary"/>
                <field name="location_id"/>
                <field name="batch_id" optional="show"/>
                <field name="name" optional="hide"/>
                <field name="state"/>
                <field name="reschedule_count" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_repair_pickup_appointment_form" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.form</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm_manual" type="object"
                            string="Confirmer le rendez-vous" class="btn-primary"
                            invisible="state != 'pending' or not pickup_date"/>
                    <button name="action_mark_done" type="object"
                            string="Marquer terminé" class="btn-primary"
                            invisible="state != 'scheduled'"/>
                    <button name="action_mark_no_show" type="object"
                            string="Marquer absent"
                            invisible="state != 'scheduled'"/>
                    <button name="action_cancel" type="object"
                            string="Annuler"
                            confirm="Annuler ce rendez-vous ?"
                            invisible="state in ('done','no_show','cancelled')"/>
                    <button name="action_mark_contacted" type="object"
                            string="Contacté"
                            invisible="not escalation_activity_id"/>
                    <button name="action_send_reminder_now" type="object"
                            string="Renvoyer le rappel"
                            invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,scheduled,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_batch" type="object" class="oe_stat_button"
                                icon="fa-folder-open">
                            <field name="batch_id" widget="statinfo" string="Dossier"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="batch_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                            <field name="device_count" readonly="1"/>
                            <field name="device_summary" readonly="1"/>
                        </group>
                        <group>
                            <field name="pickup_date"/>
                            <field name="reschedule_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Appareils à préparer">
                            <field name="repair_ids" readonly="1">
                                <tree>
                                    <field name="device_id_name" string="Appareil"/>
                                    <field name="serial_number"/>
                                    <field name="product_tmpl_id" string="Modèle" optional="show"/>
                                    <field name="variant_id" optional="hide"/>
                                    <field name="category_id" optional="hide"/>
                                    <field name="pickup_location_id" string="Lieu d'origine" optional="show"/>
                                    <field name="notes" optional="hide"/>
                                    <field name="name" string="Réf." optional="hide"/>
                                    <field name="state"/>
                                </tree>
                                <kanban>
                                    <field name="name"/>
                                    <field name="device_id_name"/>
                                    <field name="serial_number"/>
                                    <field name="device_picture"/>
                                    <field name="pickup_location_id"/>
                                    <field name="state"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                                <t t-if="record.device_picture.raw_value">
                                                    <div class="o_kanban_image_fill_left d_block"
                                                         t-attf-style="background-image: url(#{kanban_image('repair.order', 'device_picture', record.id.raw_value)})"/>
                                                </t>
                                                <div class="oe_kanban_details">
                                                    <strong><field name="device_id_name"/></strong>
                                                    <div t-if="record.serial_number.raw_value">
                                                        SN: <field name="serial_number"/>
                                                    </div>
                                                    <div class="text-muted">
                                                        <field name="name"/> · <field name="pickup_location_id"/>
                                                    </div>
                                                    <div>
                                                        <field name="state" widget="badge"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Suivi">
                            <group>
                                <field name="notification_sent_at" readonly="1"/>
                                <field name="last_reminder_sent_at" readonly="1"/>
                                <field name="contacted" readonly="1"/>
                                <field name="contacted_at" readonly="1"/>
                                <field name="escalation_activity_id" readonly="1"/>
                                <field name="token" readonly="1"
                                       groups="repair_custom.group_repair_admin"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Calendar view -->
    <record id="view_repair_pickup_appointment_calendar" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.calendar</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Rendez-vous de retrait"
                      date_start="pickup_date"
                      color="location_id"
                      mode="month"
                      quick_create="0">
                <field name="partner_id"/>
                <field name="device_count"/>
                <field name="device_summary"/>
                <field name="batch_id"/>
                <field name="location_id" filters="1"/>
                <field name="state" filters="1"/>
            </calendar>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_repair_pickup_appointment_search" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.search</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="batch_id"/>
                <filter name="pending" string="En attente"
                        domain="[('state','=','pending')]"/>
                <filter name="scheduled" string="Confirmés"
                        domain="[('state','=','scheduled')]"/>
                <filter name="to_contact" string="À contacter"
                        domain="[('escalation_activity_id','!=',False)]"/>
                <filter name="today" string="Aujourd'hui"
                        domain="[('pickup_date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_week" string="Cette semaine"
                        domain="[('pickup_date','&gt;=', (context_today() + relativedelta(weekday=0, days=-6)).strftime('%Y-%m-%d')),
                                 ('pickup_date','&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_location" string="Lieu"
                            context="{'group_by': 'location_id'}"/>
                    <filter name="group_state" string="État"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Client"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_repair_pickup_appointment" model="ir.actions.act_window">
        <field name="name">Rendez-vous de retrait</field>
        <field name="res_model">repair.pickup.appointment</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="search_view_id" ref="view_repair_pickup_appointment_search"/>
        <field name="context">{'search_default_pending': 1, 'search_default_scheduled': 1}</field>
    </record>

    <!-- Daily agenda tree -->
    <record id="view_repair_pickup_appointment_agenda_tree" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.agenda.tree</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <tree string="Agenda du jour"
                  decoration-bf="pickup_date == context_today().strftime('%Y-%m-%d')"
                  decoration-muted="pickup_date &gt; context_today().strftime('%Y-%m-%d')"
                  create="false">
                <field name="pickup_date"/>
                <field name="partner_id"/>
                <field name="primary_device_id" string="Appareil"/>
                <field name="primary_device_category_id" string="Catégorie"/>
                <field name="location_id"/>
                <field name="batch_id"/>
                <field name="reschedule_count" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Daily agenda search (adds the today-or-tomorrow filter) -->
    <record id="view_repair_pickup_appointment_agenda_search" model="ir.ui.view">
        <field name="name">repair.pickup.appointment.agenda.search</field>
        <field name="model">repair.pickup.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="batch_id"/>
                <filter name="today_or_tomorrow" string="Aujourd'hui + demain"
                        domain="[('state','=','scheduled'),
                                 ('pickup_date','&gt;=', context_today().strftime('%Y-%m-%d')),
                                 ('pickup_date','&lt;=', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="today_only" string="Aujourd'hui"
                        domain="[('state','=','scheduled'),
                                 ('pickup_date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="1" string="Grouper par">
                    <filter name="group_date" string="Jour"
                            context="{'group_by': 'pickup_date'}"/>
                    <filter name="group_location" string="Lieu"
                            context="{'group_by': 'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_repair_pickup_appointment_daily_agenda"
            model="ir.actions.act_window">
        <field name="name">Agenda du jour</field>
        <field name="res_model">repair.pickup.appointment</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_repair_pickup_appointment_agenda_tree"/>
        <field name="search_view_id"
               ref="view_repair_pickup_appointment_agenda_search"/>
        <field name="context">{
            'search_default_today_or_tomorrow': 1,
            'search_default_group_date': 1,
            'search_default_group_location': 1
        }</field>
    </record>
</odoo>
