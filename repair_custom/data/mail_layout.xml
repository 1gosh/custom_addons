<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="mail_notification_layout"
                  name="Repair: notification layout (logo + footer only)"
                  inherit_id="mail.mail_notification_layout" primary="True">
            <xpath expr="//div[@summary='o_mail_notification']" position="replace">
                <div t-if="company and not company.uses_default_logo"
                     style="padding: 0 0 16px 0;">
                    <img t-att-src="'/logo.png?company=%s' % company.id"
                         t-att-alt="'%s' % company.name"
                         style="padding: 0; margin: 0; height: auto; max-height: 48px;"/>
                </div>
            </xpath>
            <xpath expr="//t[hasclass('o_signature')]" position="replace"/>
            <xpath expr="//b[@t-out='company.name']/.." position="replace">
                <div style="margin: 16px 0px 4px 0px; padding: 16px 0 0; border-top: 1px solid #999999; font-size: 11px;">
                    <span style="font-weight: bold;" t-out="company.name"/><br/>
                    <p style="color: #555; margin-top:2px;">
                        <t t-out="company.phone"/>
                        <t t-if="company.email and company.phone"> |</t>
                        <a t-if="company.email" t-att-href="'mailto:%s' % company.email"
                            style="text-decoration:none; color: #555;" t-out="company.email"/>
                        <t t-if="company.website and (company.phone or company.email)"> |</t>
                        <a t-if="company.website" t-att-href="'%s' % company.website"
                            style="text-decoration:none; color: #555;" t-out="company.website"/>
                    </p>
                </div>
            </xpath>
            <xpath expr="//span[@id='mail_unfollow']/.." position="replace">
                <div style="font-size: 11px;">
                    <a href="/mail/unfollow" style="text-decoration: none; color:#999999;">Se désabonner</a>
                </div>
            </xpath>
        </template>
    </data>
</odoo>
