<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_pickup_ready" model="mail.template">
            <field name="name">Appareil prêt : prendre un RDV de retrait</field>
            <field name="model_id" ref="model_repair_pickup_appointment"/>
            <field name="subject">Votre dépot est prêt à être récupéré</field>
            <field name="email_from">{{ object.company_id.email_formatted or user.email_formatted }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, Helvetica, sans-serif; color: #000; max-width: 600px; font-size: 14px; line-height: 1.5;">
                    <p style="margin: 0 0 16px;">Bonjour,</p>

                    <t t-set="ready_repairs" t-value="object.batch_id.repair_ids.filtered(lambda r: r.delivery_state != 'abandoned' and r.state in ('done', 'irreparable'))"/>
                    <t t-set="done_count" t-value="len(ready_repairs.filtered(lambda r: r.state == 'done'))"/>
                    <p style="margin: 0 0 16px;">
                        <t t-if="done_count == 1">Votre appareil est réparé, </t>
                        <t t-elif="done_count &gt; 1">Vos appareils sont réparés, </t>
                        <t t-else="">Votre dossier <strong t-out="object.batch_id.name or ''"/> est prêt pour le retrait, </t>
                        planifiez le retrait via notre calendrier en ligne en cliquant sur le bouton ci-dessous.
                    </p>

                    <p style="margin: 24px 0;">
                        <a t-att-href="object._portal_url()"
                           style="display: inline-block; padding: 12px 28px; background-color: #000; color: #fff;
                                  text-decoration: none; font-weight: bold; letter-spacing: 1px;
                                  text-transform: uppercase; font-size: 13px;">
                            Prendre rendez-vous
                        </a>
                    </p>

                    <p style="margin: 24px 0 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #000; padding-bottom: 4px;">
                        Récapitulatif du dépôt
                    </p>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
                        <tr>
                            <td style="padding: 4px 0; width: 40%;"><strong>Date de dépôt</strong></td>
                            <td style="padding: 4px 0;"><t t-out="object.batch_id.date and object.batch_id.date.strftime('%d/%m/%Y') or ''"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 4px 0;"><strong>Lieu de retrait</strong></td>
                            <td style="padding: 4px 0;"><t t-out="object.location_id.display_name or ''"/></td>
                        </tr>
                    </table>

                    <p style="margin: 24px 0 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #000; padding-bottom: 4px;">
                        Appareils
                    </p>
                    <t t-foreach="object.batch_id.repair_ids.filtered(lambda r: r.delivery_state != 'abandoned' and r.state in ('done', 'irreparable'))" t-as="repair">
                        <div style="margin: 0 0 16px; padding: 12px 0 12px 16px; border-left: 2px solid #000;">
                            <p style="margin: 0 0 8px; font-weight: bold;" t-out="repair.device_id_name or ''"/>

                            <t t-if="repair.tag_ids">
                                <p style="margin: 0 0 6px;"><em>Pannes constatées :</em>
                                    <t t-out="', '.join(repair.tag_ids.mapped('name'))"/>
                                </p>
                            </t>

                            <t t-if="repair.state == 'done' and repair.internal_notes">
                                <p style="margin: 0 0 4px;"><em>Intervention :</em></p>
                                <p style="margin: 0 0 6px;" t-out="repair.internal_notes or ''"/>
                            </t>
                            <t t-if="repair.state == 'irreparable'">
                                <p style="margin: 0 0 6px;"><em>Diagnostic :</em> cet appareil n'a pas pu être réparé.</p>
                                <t t-if="repair.internal_notes">
                                    <p style="margin: 0 0 6px;" t-out="repair.internal_notes or ''"/>
                                </t>
                            </t>

                            <t t-if="repair.notes">
                                <p style="margin: 0 0 4px;"><em>Informations complémentaires :</em></p>
                                <p style="margin: 0;" t-out="repair.notes or ''"/>
                            </t>
                        </div>
                    </t>

                    <p style="margin: 32px 0 0;">À bientôt,<br/>L’équipe Hifi Vintage Paris</p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang or 'fr_FR' }}</field>
            <field name="auto_delete" eval="False"/>
        </record>

        <record id="mail_template_pickup_reminder" model="mail.template">
            <field name="name">Rappel : RDV retrait</field>
            <field name="model_id" ref="model_repair_pickup_appointment"/>
            <field name="subject">DÉPOT PRÊT — relance</field>
            <field name="email_from">{{ object.company_id.email_formatted or user.email_formatted }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, Helvetica, sans-serif; color: #000; max-width: 600px; font-size: 14px; line-height: 1.5;">
                    <p style="margin: 0 0 16px;">Bonjour,</p>

                    <t t-set="done_count" t-value="len(object.batch_id.repair_ids.filtered(lambda r: r.delivery_state != 'abandoned' and r.state == 'done'))"/>
                    <p style="margin: 0 0 16px;">
                        <t t-if="done_count == 1">Votre appareil est réparé, </t>
                        <t t-elif="done_count &gt; 1">Vos appareils sont réparés, </t>
                        <t t-else="">Votre dossier <strong t-out="object.batch_id.name or ''"/> est prêt pour le retrait, </t>
                        nous vous invitons à planifier son retrait via notre calendrier en ligne, cliquez sur le bouton ci-dessous.
                    </p>

                    <p style="margin: 24px 0;">
                        <a t-att-href="object._portal_url()"
                           style="display: inline-block; padding: 12px 28px; background-color: #000; color: #fff;
                                  text-decoration: none; font-weight: bold; letter-spacing: 1px;
                                  text-transform: uppercase; font-size: 13px;">
                            Prendre rendez-vous
                        </a>
                    </p>

                    <p style="margin: 32px 0 0;">À très bientôt,<br/>L’équipe Hifi Vintage Paris</p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang or 'fr_FR' }}</field>
            <field name="auto_delete" eval="False"/>
        </record>

        <record id="mail_template_pickup_reschedule" model="mail.template">
            <field name="name">RDV retrait : déplacement</field>
            <field name="model_id" ref="model_repair_pickup_appointment"/>
            <field name="subject">Votre rendez-vous de retrait a été déplacé</field>
            <field name="email_from">{{ object.company_id.email_formatted or user.email_formatted }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, Helvetica, sans-serif; color: #000; max-width: 600px; font-size: 14px; line-height: 1.5;">
                    <p style="margin: 0 0 16px;">Bonjour,</p>

                    <p style="margin: 0 0 16px;">
                        Votre rendez-vous de retrait a été déplacé au
                        <strong t-out="object.pickup_date and object.pickup_date.strftime('%d/%m/%Y') or ''"/>.
                    </p>

                    <p style="margin: 24px 0;">
                        <a t-att-href="object._portal_url()"
                           style="display: inline-block; padding: 12px 28px; background-color: #000; color: #fff;
                                  text-decoration: none; font-weight: bold; letter-spacing: 1px;
                                  text-transform: uppercase; font-size: 13px;">
                            Voir mon rendez-vous
                        </a>
                    </p>

                    <p style="margin: 32px 0 0;">Bien à vous,<br/>L’équipe Hifi Vintage Paris</p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang or 'fr_FR' }}</field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
